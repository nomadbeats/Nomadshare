# NomadShare - Environment Variables
# Copy to .env for local dev; set the same keys in Vercel's dashboard for deployment.

BOT_TOKEN=your_bot_token
BOT_USERNAME=your_bot_username_without_@

SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Space-separated Telegram user IDs
ADMINS=123456789 987654321

# Optional: -100 followed by channel ID
LOG_CHANNEL=

# Auto-delete files after this many seconds (0/blank = never)
AUTO_DELETE_TIME=1800

# Optional external URL shortener
SHORTLINK_URL=
SHORTLINK_API=

# Your deployed Vercel URL (for reference when setting the Telegram webhook)
WEBSITE_URL=https://your-project.vercel.app

# Community/updates channels linked as buttons on /start (no @)
COMMUNITY_CHANNEL=nomadry
UPDATES_CHANNEL=nomadrybots
