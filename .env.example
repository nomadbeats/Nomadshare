# NomadShare - Environment Variables Template
# Copy this file to .env and fill in your values

# ============ TELEGRAM BOT CONFIGURATION ============
API_ID=your_api_id
API_HASH=your_api_hash
BOT_TOKEN=your_bot_token
BOT_USERNAME=your_bot_username_without_@

# ============ SUPABASE CONFIGURATION ============
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# ============ CLONE BOT CONFIGURATION (Optional) ============
CLONE_MODE=False
CLONE_SUPABASE_URL=clone_supabase_url
CLONE_SUPABASE_KEY=clone_supabase_key

# ============ ADMIN CONFIGURATION ============
# Separate multiple admin IDs with space
ADMINS=123456789 987654321

# ============ LOG CHANNEL ============
# Start with -100 followed by channel ID
LOG_CHANNEL=-100your_channel_id

# ============ AUTO-DELETE CONFIGURATION ============
AUTO_DELETE_MODE=True
AUTO_DELETE=30
AUTO_DELETE_TIME=1800

# ============ URL SHORTENER CONFIGURATION ============
VERIFY_MODE=False
SHORTLINK_URL=your_shortener_domain.com
SHORTLINK_API=your_shortener_api_key
VERIFY_TUTORIAL=https://example.com/how-to-verify

# ============ WEBSITE URL MODE ============
WEBSITE_URL_MODE=False
WEBSITE_URL=https://your-website.com

# ============ STREAM CONFIGURATION ============
STREAM_MODE=True
SLEEP_THRESHOLD=60
PING_INTERVAL=1200

# ============ SERVER CONFIGURATION ============
URL=https://your-server-url/
PORT=8080

# ============ FILE CAPTIONS ============
CUSTOM_FILE_CAPTION=Uploaded via NomadShare
BATCH_FILE_CAPTION=Uploaded via NomadShare - Batch Upload

# ============ PUBLIC FILE STORE ============
PUBLIC_FILE_STORE=True
